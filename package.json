{
  "name": "scansentry",
  "version": "1.0.2",
  "description": "On-demand Windows scan tool: malware hash check, junk/temp cleanup, startup audit, browser hijack detection.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icons": "electron scripts/render-icons.js",
    "smoke": "electron scripts/smoke-electron.js",
    "dist": "electron-builder --win"
  },
  "author": "GokuofGotham",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.gokuofgotham.scansentry",
    "productName": "ScanSentry",
    "copyright": "Copyright (C) 2026 GokuofGotham",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "files": [
      "assets/icon.ico",
      "main.js",
      "preload.js",
      "quarantine.js",
      "settings.js",
      "scanners/**/*",
      "src/**/*"
    ]
  }
}
