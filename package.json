{
  "name": "scansentry",
  "version": "1.0.1",
  "description": "On-demand Windows scan tool: malware hash check, junk/temp cleanup, startup audit, browser hijack detection.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icons": "electron scripts/render-icons.js",
    "smoke": "electron scripts/smoke-electron.js",
    "dist": "electron-builder --win"
  },
  "author": "Julio",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.local.scansentry",
    "productName": "ScanSentry",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "files": [
      "assets/icon.ico",
      "main.js",
      "preload.js",
      "quarantine.js",
      "settings.js",
      "scanners/**/*",
      "src/**/*"
    ]
  }
}
